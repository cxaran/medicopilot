NODE_ENV=development
PORT=8081
HOST=0.0.0.0
GATEWAY_PUBLIC_PATH_PREFIX=/model-gateway
GATEWAY_ENABLE_ROOT_PATH_ALIAS=true
GATEWAY_PUBLIC_COOKIE_NAME=mg_session
GATEWAY_ALLOWED_ORIGINS=http://localhost:3000
GATEWAY_GLOBAL_MAX_CONTEXT_TOKENS=128000
GATEWAY_SAFETY_RESERVE_TOKENS=1024
GATEWAY_MAX_WS_MESSAGE_BYTES=1048576
GATEWAY_MAX_TOOLS_PER_TURN=16
GATEWAY_MAX_TOOL_RESULT_BYTES=65536
GATEWAY_TOOL_RESULT_TIMEOUT_MS=30000
GATEWAY_DEV_TICKET=dev-ticket
# MG-002: secreto HS256 compartido con FastAPI para verificar el connection-ticket.
# Debe coincidir con AGENT_GATEWAY_TICKET_SECRET del backend. Vacío => solo dev-ticket.
GATEWAY_AGENT_TICKET_SECRET=
# B4 (puente de arriendo de credencial): URL base del backend FastAPI interno y
# secreto compartido server-to-server (debe coincidir con AGENT_GATEWAY_INTERNAL_SECRET
# del backend). Si ambos están definidos, el gateway arrienda credenciales reales contra
# FastAPI; si faltan, usa el control-plane fake (dev/tests).
GATEWAY_BACKEND_INTERNAL_URL=
GATEWAY_BACKEND_INTERNAL_SECRET=
# B5: proveedor real opencode (OpenAI-compatible). Solo el base URL es configurable;
# la API key NO se pone aqui (llega por arriendo de credencial de B4). El modelo por
# defecto debe EXISTIR en el catalogo real de opencode zen (su /models no expone
# "gpt-4o-mini"; si ofrece claude-*, gemini-*, gpt-5.x, etc.).
GATEWAY_OPENCODE_BASE_URL=https://opencode.ai/zen/v1
GATEWAY_OPENCODE_DEFAULT_MODEL=claude-haiku-4-5
# OpenCode Go (suscripcion): misma API OpenAI-compatible, otro endpoint y catalogo. La
# MISMA key opencode arrendada sirve, pero el proveedor se modela como opencode_go.
# Opt-in: solo se registra si GATEWAY_OPENCODE_GO_ENABLED=true.
GATEWAY_OPENCODE_GO_ENABLED=false
GATEWAY_OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
GATEWAY_OPENCODE_GO_DEFAULT_MODEL=qwen3.7-plus
# OpenAI / Codex (P6): un provider id "openai" con dos auth shapes (API key vs OAuth ChatGPT
# Plus). La credencial NO se pone aqui: llega por arriendo (B4/B10). apiFlavor elige la
# familia de cable: chat_completions (API key) o codex_responses (app-server de la
# suscripcion). Opt-in: solo se registra si GATEWAY_OPENAI_ENABLED=true.
GATEWAY_OPENAI_ENABLED=false
GATEWAY_OPENAI_BASE_URL=https://api.openai.com/v1
GATEWAY_OPENAI_DEFAULT_MODEL=gpt-5-codex
GATEWAY_OPENAI_API_FLAVOR=chat_completions
# Anthropic (Messages API, FAMILIA DE CABLE distinta a OpenAI): provider id "anthropic". La
# credencial NO se pone aqui (llega por arriendo de B3/B4, cifrada por usuario). Auth por
# x-api-key + header anthropic-version. El razonamiento es "extended thinking" por presupuesto
# de tokens. Opt-in: solo se registra si GATEWAY_ANTHROPIC_ENABLED=true.
GATEWAY_ANTHROPIC_ENABLED=false
GATEWAY_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GATEWAY_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
# Google Gemini (Generative Language API, TERCERA familia de cable): provider id "gemini". La
# credencial NO se pone aqui (llega por arriendo de B3/B4, cifrada por usuario). Auth por header
# x-goog-api-key. El razonamiento es thinkingConfig.thinkingBudget (tokens). El endpoint es por
# modelo (/models/{id}:streamGenerateContent). Opt-in: solo se registra si GATEWAY_GEMINI_ENABLED=true.
GATEWAY_GEMINI_ENABLED=false
GATEWAY_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GATEWAY_GEMINI_DEFAULT_MODEL=gemini-2.5-flash
