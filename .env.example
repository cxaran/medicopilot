PROJECT_NAME=MedicoPilot
ENVIRONMENT=local
TRUSTED_BROWSER_ORIGINS=http://localhost:3000

SECRET_KEY=change-me-use-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
EMAIL_TOKEN_EXPIRE_MINUTES=30
TRYS_BEFORE_LOCK=5

# Ticket de conexión al Agent Gateway (puente firmado FastAPI<->Gateway). Secreto
# DEDICADO (no reutilizar SECRET_KEY). Obligatorio en producción; en local/staging,
# si se deja vacío, se deriva de SECRET_KEY. TTL corto en segundos (rango 60-120).
AGENT_GATEWAY_TICKET_SECRET=change-me-use-a-long-random-agent-ticket-secret
AGENT_GATEWAY_TICKET_TTL_SECONDS=90

# Clave Fernet DEDICADA para cifrar en reposo los secretos de credenciales de IA.
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AI_CREDENTIAL_KEY=change-me-use-a-valid-fernet-key-base64-32-bytes

# Puente INTERNO server-to-server (B4): secreto compartido con el Agent Gateway para
# el endpoint /api/v1/internal/agent/credential-lease (header X-Internal-Auth).
# DISTINTO del ticket. Endpoint interno: detrás de red interna, nunca público.
AGENT_GATEWAY_INTERNAL_SECRET=change-me-use-a-long-random-internal-secret
AGENT_GATEWAY_LEASE_TTL_SECONDS=120

# OAuth ChatGPT Plus/Codex (B10): flujo browser-callback PKCE para conectar la cuenta
# del médico. Configura CLIENT_ID y REDIRECT_URI para habilitar los endpoints; si
# faltan, responden 503. El perfil OAuth se guarda CIFRADO; nunca se loguean tokens.
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
OPENAI_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
OPENAI_OAUTH_REDIRECT_URI=
OPENAI_OAUTH_SCOPE=openid profile email offline_access
OPENAI_OAUTH_REFRESH_SKEW_SECONDS=60

# Investigación PubMed (B13): proxy server-side a las E-utilities de NCBI (no toca el
# expediente). La API key es OPCIONAL (sube el límite de tasa de NCBI); nunca se loguea.
NCBI_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
NCBI_API_KEY=
NCBI_TIMEOUT_SECONDS=10.0

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

POSTGRES_USER=medicopilot
POSTGRES_PASSWORD=medicopilot
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=medicopilot

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=dev@example.com
SMTP_PASSWORD=dev-password
SMTP_FROM_EMAIL=dev@example.com
SMTP_FROM_NAME=MedicoPilot Dev
SMTP_TLS=false
SMTP_SSL=false
SMTP_USE_CREDENTIALS=false

# Usado por: python -m backend.app.core.bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin1234
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=MedicoPilot
BOOTSTRAP_ADMIN_ROLE_NAME=Administrador
BOOTSTRAP_USER_ROLE_NAME=Usuario

# Usado por Bootstrap HTTP de producto (/api/v1/bootstrap/*). Obligatorio en production.
BOOTSTRAP_SETUP_TOKEN=change-me-use-a-long-random-bootstrap-token

# --- Respaldos a Google Drive ---
# Kill-switch de emergencia del tick (el interruptor real está en la UI):
BACKUPS_ENABLED=true
# DEPRECADA: el flag vive en la UI (backup_settings); sólo importación inicial.
BACKUP_EXPLORER_ENABLED=false
BACKUP_TEMP_DIR=/tmp/medicopilot-backups
BACKUP_RUN_LEASE_MINUTES=120
BACKUP_MAX_ATTEMPTS=3
# Fernet (cifra el refresh token de Drive en reposo):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_TOKEN_ENCRYPTION_KEY=
# App OAuth "web" de Google Cloud (scope drive.file) — FALLBACK de despliegue:
# lo normal es pegar las credenciales en la UI (/backups) y verificar el dominio.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/v1/backups/google-drive/callback

# --- Política de auth pública ---
# Candado de DESPLIEGUE del registro público: la política real se edita en la UI
# (Configuración del sistema), pero solo tiene efecto si el despliegue lo permite.
# Sin valor: permitido únicamente en ENVIRONMENT=local.
REGISTRATION_ALLOWED=false
PASSWORD_RESET_ENABLED=true
